<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Platform Login Test Suite"
       parallel="methods"
       thread-count="2"
       data-provider-thread-count="2">

    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <test name="Cross Platform Authentication Tests">
        <groups>
            <run>
                <include name="web"/>
                <include name="android"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginAutomationTest"/>
        </classes>
    </test>

</suite>